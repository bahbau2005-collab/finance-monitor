# ===========================================
# Contoh konfigurasi environment backend.
# Salin file ini jadi ".env" lalu isi nilainya.
# JANGAN taruh nilai asli/rahasia di file .example ini.
# ===========================================

# Koneksi MongoDB.
# Lokal:  mongodb://localhost:27017/keuangan-app
# Atlas:  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/keuangan-app
MONGODB_URI=mongodb://localhost:27017/keuangan-app

# Port server (Render akan mengisinya otomatis)
PORT=5000
NODE_ENV=development

# Daftar origin frontend yang diizinkan (dipisah koma).
# Saat hosting, tambahkan URL Vercel, contoh: https://keuangan-eden.vercel.app
CORS_ORIGIN=http://localhost:3000,http://192.168.100.11:3000

# Password untuk login ke aplikasi (ganti dengan password kuat saat hosting)
APP_PASSWORD=gantipasswordini

# Kunci rahasia penandatangan token. Buat acak & panjang, jangan dibagikan.
JWT_SECRET=isi-dengan-string-acak-panjang
